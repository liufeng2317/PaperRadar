# Copy this file to .env and fill in local secrets.
# .env is ignored by git.

# Proxy settings for arXiv and LLM API access.
HTTP_PROXY=http://user:password@host:port
HTTPS_PROXY=http://user:password@host:port

# Some Python/network tools also read lowercase proxy names.
http_proxy=http://user:password@host:port
https_proxy=http://user:password@host:port

# OpenAI-compatible LLM settings.
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional MinerU parser integration.
# Used only when config/default.json has "parse_pdfs": true.
# PaperRadar includes the paper_parse integration internally; no KGFORGE_PATH is needed.
MINERU_API_BASE=https://api.mineru.example.com
MINERU_API_KEY=your-mineru-api-key
PJLAB_API_KEY=your-llm-key-for-mineru-title-enhancement
PJLAB_API_BASE_URL=https://api.llm.example.com
PJLAB_API_CHAT_MODEL=model-name
